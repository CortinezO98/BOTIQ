# ═══════════════════════════════════════════════════════
# BOTIQ — Variables de Entorno
# Windows CMD:  copy backend\.env.example backend\.env
# Linux/Mac:    cp backend/.env.example backend/.env
# ═══════════════════════════════════════════════════════

ENVIRONMENT=development
DEBUG=true
APP_NAME=BOTIQ
APP_VERSION=1.1.0

# ── Base de Datos ─────────────────────────────────────
DATABASE_URL=postgresql://botiq_user:botiq_pass@db:5432/botiq_db

# ── Seguridad JWT ─────────────────────────────────────
# Windows CMD: docker run --rm python:3.11-slim python -c "import secrets; print(secrets.token_hex(32))"
# PowerShell:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_genera_con_el_comando_de_arriba
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Google Cloud ──────────────────────────────────────
GCP_PROJECT_ID=tu-proyecto-id-en-gcp
GCP_LOCATION=us-central1
# Ruta dentro del contenedor Docker
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# ── Vertex AI — Modelos ───────────────────────────────
VERTEX_FAST_MODEL=gemini-2.5-flash
VERTEX_REASONING_MODEL=gemini-2.5-pro
VERTEX_MULTIMODAL_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-multilingual-embedding-002

# ── Parámetros RAG ────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.72
MAX_OUTPUT_TOKENS=1024
VERTEX_TIMEOUT_SECONDS=30

# ── Google Drive RAG ──────────────────────────────────
# PASO 1: Ve a Google Drive
# PASO 2: Crea carpeta "BOTIQ - Base de Conocimiento"
# PASO 3: Comparte con el email del Service Account (Lector)
# PASO 4: Copia el ID de la URL: drive.google.com/drive/folders/ESTE_ID
GDRIVE_FOLDER_ID=pega_aqui_el_id_de_la_carpeta

# ── Document AI (para PDFs escaneados) ───────────────
# Dejar vacío si no tienes PDFs escaneados
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_LOCATION=us

# ── Cloud Storage (imágenes del chat) ─────────────────
GCS_BUCKET_NAME=botiq-images-bucket

# ── API Tablero de Servidores ─────────────────────────
# Dejar vacío para usar datos demo en desarrollo
SERVER_DASHBOARD_API_URL=
SERVER_DASHBOARD_API_KEY=

# ── ChromaDB (sobreescrito por Docker) ───────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=botiq_knowledge_base

# ── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5180,http://localhost:5190,http://localhost:3000
