ENVIRONMENT=development
DEBUG=true
APP_NAME=BOTIQ
APP_VERSION=1.2.0

DATABASE_URL=postgresql://botiq_user:botiq_pass@db:5432/botiq_db

SECRET_KEY=CAMBIA_ESTO_genera_con_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

VERTEX_FAST_MODEL=gemini-2.5-flash
VERTEX_REASONING_MODEL=gemini-2.5-pro
VERTEX_MULTIMODAL_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-multilingual-embedding-002

RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.72
MAX_OUTPUT_TOKENS=1024
VERTEX_TIMEOUT_SECONDS=30

GDRIVE_FOLDER_ID=
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_LOCATION=us
GCS_BUCKET_NAME=botiq-images-bucket

SERVER_DASHBOARD_API_URL=
SERVER_DASHBOARD_API_KEY=

CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=botiq_knowledge_base

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5180,http://localhost:5190,http://localhost:3000

MAX_QUESTIONS_PER_SESSION=8
MAX_OUT_OF_SCOPE_PER_SESSION=1
MAX_MESSAGE_LENGTH=1200
REQUIRE_SUPPORT_NETWORK_VALIDATION=true
SUPPORT_ALLOWED_EMAIL_DOMAINS=iq-online.com

BUSINESS_SCOPE_KEYWORDS=portal,sistema,aplicacion,aplicación,correo,outlook,excel,word,teams,vpn,contraseña,password,login,acceso,servidor,server,base de conocimiento,documentación,documentacion,procedimiento,incidente,soporte,aranda,red,firewall,certificado,ssl,backup,memoria,cpu,disco,latencia
