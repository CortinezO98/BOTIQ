# ═══════════════════════════════════════════════════════════
# BOTIQ — Variables de Entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA subas el .env al repositorio
# ═══════════════════════════════════════════════════════════

# ── Entorno ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=BOTIQ
APP_VERSION=1.0.0

# ── Base de Datos ─────────────────────────────────────────────────────────────
# En Docker se sobreescribe desde docker-compose.yml
DATABASE_URL=postgresql://botiq_user:botiq_pass@localhost:5432/botiq_db

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Genera una clave segura con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_genera_una_clave_de_64_caracteres_hexadecimales
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Google Cloud ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=tu-proyecto-id-en-gcp
GCP_LOCATION=us-central1
# Ruta al JSON del Service Account (dentro del contenedor Docker)
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# ── Vertex AI — Modelos ───────────────────────────────────────────────────────
VERTEX_GEMINI_MODEL=gemini-1.5-pro
VERTEX_VISION_MODEL=gemini-1.5-pro
VERTEX_EMBEDDING_MODEL=text-multilingual-embedding-002

# ── Vertex AI — Vector Search (opcional, para producción) ────────────────────
VERTEX_VECTOR_SEARCH_INDEX_ID=
VERTEX_VECTOR_SEARCH_ENDPOINT_ID=

# ── Document AI (opcional, para PDFs escaneados) ─────────────────────────────
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_LOCATION=us

# ── Google Drive (carpeta con docs del RAG) ───────────────────────────────────
# ID de la carpeta: extraer de la URL de Drive
# https://drive.google.com/drive/folders/ESTE_ES_EL_ID
GDRIVE_FOLDER_ID=

# ── Cloud Storage ─────────────────────────────────────────────────────────────
GCS_BUCKET_NAME=botiq-images-bucket

# ── API Tablero de Servidores ─────────────────────────────────────────────────
SERVER_DASHBOARD_API_URL=https://tu-api-servidores.com
SERVER_DASHBOARD_API_KEY=tu-api-key-del-tablero

# ── ChromaDB (se sobreescribe desde docker-compose) ──────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=botiq_knowledge_base

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
