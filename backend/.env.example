# ═══════════════════════════════════════════════════════════════════
# BOTIQ v1.1.0 — Variables de Entorno
# cp backend/.env.example backend/.env  y completar valores reales
# NUNCA subir .env al repositorio
# ═══════════════════════════════════════════════════════════════════

# ── Entorno ───────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=BOTIQ
APP_VERSION=1.1.0

# ── Base de Datos ─────────────────────────────────────────────────
# En Docker se sobreescribe desde docker-compose
DATABASE_URL=postgresql://botiq_user:botiq_pass@localhost:5432/botiq_db

# ── Seguridad JWT ─────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_minimo_64_chars_hexadecimales_aleatorios
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Google Cloud ──────────────────────────────────────────────────
GCP_PROJECT_ID=tu-proyecto-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# ── Vertex AI — Modelos por propósito ─────────────────────────────
VERTEX_FAST_MODEL=gemini-2.5-flash
VERTEX_REASONING_MODEL=gemini-2.5-pro
VERTEX_MULTIMODAL_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-multilingual-embedding-002

# ── Parámetros RAG ────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.72
MAX_OUTPUT_TOKENS=1024
VERTEX_TIMEOUT_SECONDS=30

# ── Document AI (para PDFs escaneados) ────────────────────────────
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_LOCATION=us

# ── Google Drive ──────────────────────────────────────────────────
# ID de carpeta: de la URL https://drive.google.com/drive/folders/ESTE_ID
GDRIVE_FOLDER_ID=

# ── Cloud Storage ─────────────────────────────────────────────────
GCS_BUCKET_NAME=botiq-images-bucket

# ── API Tablero de Servidores ─────────────────────────────────────
# Si está vacío: usa datos demo en dev, error en prod
SERVER_DASHBOARD_API_URL=
SERVER_DASHBOARD_API_KEY=

# ── ChromaDB (sobreescrito por Docker) ────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=botiq_knowledge_base

# ── CORS ──────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
