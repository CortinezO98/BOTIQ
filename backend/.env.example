# ─── Entorno ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME=BOTIQ
APP_VERSION=1.0.0

# ─── Base de Datos ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://botiq_user:botiq_pass@localhost:5432/botiq_db

# ─── Seguridad JWT ───────────────────────────────────────────────────────────
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_AL_MENOS_32_CARACTERES
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Google Cloud ────────────────────────────────────────────────────────────
GCP_PROJECT_ID=tu-proyecto-gcp-id
GCP_LOCATION=us-central1
# Ruta al archivo JSON del Service Account
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

# ─── Vertex AI — Modelos ─────────────────────────────────────────────────────
VERTEX_GEMINI_MODEL=gemini-1.5-pro
VERTEX_VISION_MODEL=gemini-1.5-pro
VERTEX_EMBEDDING_MODEL=text-multilingual-embedding-002

# ─── Vertex AI — Vector Search (RAG) ─────────────────────────────────────────
VERTEX_VECTOR_SEARCH_INDEX_ID=
VERTEX_VECTOR_SEARCH_ENDPOINT_ID=

# ─── Document AI ─────────────────────────────────────────────────────────────
DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_LOCATION=us

# ─── Google Drive ────────────────────────────────────────────────────────────
GDRIVE_FOLDER_ID=ID_DE_LA_CARPETA_EN_GOOGLE_DRIVE

# ─── Cloud Storage ───────────────────────────────────────────────────────────
GCS_BUCKET_NAME=botiq-images-bucket

# ─── API Tablero de Servidores ────────────────────────────────────────────────
SERVER_DASHBOARD_API_URL=https://tu-api-de-servidores.com
SERVER_DASHBOARD_API_KEY=tu-api-key-del-tablero

# ─── ChromaDB (RAG local) ────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=botiq_knowledge_base

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
