ENVIRONMENT=development
DEBUG=true
APP_TIMEZONE=America/Bogota
APP_NAME=BOTIQ
APP_VERSION=1.3.0

DATABASE_URL=postgresql://botiq_user:botiq_pass@db:5432/botiq_db

SECRET_KEY=CAMBIA_ESTO_genera_con_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/service-account.json

VERTEX_FAST_MODEL=gemini-2.5-flash
VERTEX_REASONING_MODEL=gemini-2.5-pro
VERTEX_MULTIMODAL_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=text-multilingual-embedding-002

RAG_TOP_K=4
RAG_MIN_CONFIDENCE=0.72
MAX_OUTPUT_TOKENS=700
VERTEX_TIMEOUT_SECONDS=30

# Ahorro de tokens Vertex / RAG
RAG_MAX_CHUNKS_TO_PROMPT=4
RAG_MAX_CONTEXT_CHARS=5000
RAG_CHUNK_SIZE_WORDS=280
RAG_ANSWER_MAX_OUTPUT_TOKENS=800
WEB_ANSWER_MAX_OUTPUT_TOKENS=700
INTENT_CLASSIFIER_USE_GEMINI=false
EMPLOYEE_GENERAL_TECH_SKIP_RAG=true

GDRIVE_FOLDER_ID=

# Base de conocimiento independiente de SERVIDORES.
# Para un único Google Sheet usa GDRIVE_SERVERS_FILE_ID.
GDRIVE_SERVERS_FOLDER_ID=
GDRIVE_SERVERS_FOLDER_IDS=
GDRIVE_SERVERS_FILE_ID=
GDRIVE_SERVERS_FILE_IDS=
# gid de la pestaña específica del Sheet; vacío usa la primera pestaña.
GDRIVE_SERVERS_SHEET_GID=
CHROMA_SERVERS_COLLECTION_NAME=botiq_servers_knowledge_base

# Sincronización incremental del inventario de servidores.
# Cada 10 minutos BOTIQ revisa el Sheet; solo reindexa si cambió el hash.
SERVERS_KB_SYNC_INTERVAL_MINUTES=10
SERVERS_KB_SYNC_ON_STARTUP=true
SERVERS_KB_STARTUP_DELAY_SECONDS=5
SERVERS_KB_SNAPSHOT_CACHE_SECONDS=60

# Frescura y umbrales usados en resúmenes determinísticos de salud.
SERVERS_KB_STALE_AFTER_MINUTES=45
SERVERS_KB_CPU_ALERT_PCT=80
SERVERS_KB_RAM_ALERT_PCT=85
SERVERS_KB_DISK_ALERT_PCT=90

DOCUMENT_AI_PROCESSOR_ID=
DOCUMENT_AI_LOCATION=us
GCS_BUCKET_NAME=botiq-images-bucket

CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=botiq_knowledge_base

# API externa de estados de aplicativos/servidores.
# El bot la consume internamente, no el usuario.
APPLICATION_STATUS_API_URL=
APPLICATION_STATUS_API_KEY=
APPLICATION_STATUS_TIMEOUT_SECONDS=10

# Compatibilidad módulo servidores.
SERVER_DASHBOARD_API_URL=
SERVER_DASHBOARD_API_KEY=

# ── Aranda Service Desk ASDK API v8.6 ────────────────────────────────────
# Se activa únicamente después de completar y validar todos los IDs.
ARANDA_ENABLED=false
ARANDA_CREATION_ENABLED=false
ARANDA_API_URL=https://aranda.clientes.iq-online.net.co/ASDKAPI
ARANDA_ALLOWED_HOSTS=aranda.clientes.iq-online.net.co
ARANDA_USERNAME=
ARANDA_PASSWORD=

# Ya no se usa para autenticar. Se conserva vacío por compatibilidad temporal.
ARANDA_API_KEY=

ARANDA_LANGUAGE_ID=2
ARANDA_CONSOLE_ID=0
ARANDA_CONSOLE_VERSION=BOTIQ-1.0

# 1=Incidente, 2=Problema, 3=Cambio, 4=Requerimiento de servicio
ARANDA_DEFAULT_ITEM_TYPE=1
ARANDA_AUTHOR_ID=0
ARANDA_PROJECT_ID=0
ARANDA_CATEGORY_ID=0
ARANDA_GROUP_ID=0
ARANDA_SERVICE_ID=0
ARANDA_SLA_ID=0
ARANDA_REGISTRY_TYPE_ID=0
ARANDA_URGENCY_ID=0
ARANDA_CUSTOMER_ID=0
ARANDA_COMPANY_ID=0
ARANDA_RESPONSIBLE_ID=0
ARANDA_CI_ID=0

ARANDA_TIMEOUT_SECONDS=15
ARANDA_CONNECT_TIMEOUT_SECONDS=5
ARANDA_VERIFY_TLS=true
ARANDA_CA_BUNDLE=
ARANDA_CLOSE_SESSION_AFTER_REQUEST=true
ARANDA_LIST_VIEW_ID=5
ARANDA_MAX_PAGE_SIZE=50
ARANDA_MAX_SUBJECT_CHARS=180
ARANDA_MAX_DESCRIPTION_CHARS=12000
ARANDA_MAX_ATTACHMENT_BYTES=10485760

# Búsqueda web controlada como fallback para errores técnicos generales.
# Recomendado: Google Custom Search JSON API. No se usa para URLs/IPs internas.
WEB_SEARCH_ENABLED=false
WEB_SEARCH_PROVIDER=google_custom_search
WEB_SEARCH_API_URL=https://www.googleapis.com/customsearch/v1
WEB_SEARCH_API_KEY=
WEB_SEARCH_CX=
WEB_SEARCH_TIMEOUT_SECONDS=8
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_DAILY_LIMIT=100
WEB_KNOWLEDGE_AUTO_REGISTER=true
WEB_KNOWLEDGE_APPROVAL_REQUIRED=true
WEB_KNOWLEDGE_APPROVED_MIN_SCORE=72

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5180,http://localhost:5190,http://localhost:3000

MAX_QUESTIONS_PER_SESSION=8
MAX_OUT_OF_SCOPE_PER_SESSION=1
MAX_MESSAGE_LENGTH=1200
MIN_RESOLUTION_ATTEMPTS_BEFORE_TICKET=2
REQUIRE_SUPPORT_NETWORK_VALIDATION=true
SUPPORT_ALLOWED_EMAIL_DOMAINS=iq-online.com

BUSINESS_SCOPE_KEYWORDS=portal,sistema,aplicacion,aplicación,aplicativo,app,url,pagina,página,ip,correo,outlook,excel,word,teams,vpn,contraseña,password,login,acceso,servidor,server,base de conocimiento,documentación,documentacion,procedimiento,incidente,soporte,aranda,ticket,red,firewall,certificado,ssl,backup,memoria,cpu,disco,latencia,caido,caído,no responde,error
OUT_OF_SCOPE_KEYWORDS=chiste,novia,novio,apuesta,casino,política,politica,religión,religion,sexo,droga,drogas,futbol,fútbol,receta,cocina,pelicula,película,tarea escolar,poema,cancion,canción,instagram,tiktok,horoscopo,horóscopo



# Seguimiento de tickets Aranda desde el chat (solo lectura)
ARANDA_TRACKING_ENABLED=true
ARANDA_TRACKING_RATE_LIMIT=10/minute
ARANDA_TRACKING_HISTORY_LIMIT=5
ARANDA_TRACKING_FILE_LIMIT=10
# Vacío = restringir al ARANDA_PROJECT_ID. Varios: 1,2,3
ARANDA_TRACKING_ALLOWED_PROJECT_IDS=
ARANDA_TRACKING_EMPLOYEE_REQUIRE_OWNERSHIP=true
ARANDA_TRACKING_SHOW_PRIVATE_NOTES_TO_SUPPORT=false
ARANDA_TRACKING_SHOW_PRIVATE_NOTES_TO_ADMIN=true
ARANDA_TRACKING_TRY_ITEM_TYPES=4,1,2,3
